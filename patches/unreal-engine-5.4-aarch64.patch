+
+		/// <summary>
+		/// Resolves the dotnet host used for recursive UBT invocations (e.g. WriteMetadata actions).
+		/// On aarch64 Linux there is no bundled linux-arm64 dotnet - the bundled "linux" build is
+		/// x86_64 and cannot execute natively - so fall back to the system dotnet that is already
+		/// hosting this UBT process.
+		/// </summary>
+		static private FileReference ResolveDotnetPath()
+		{
+			if (RuntimePlatform.Current == RuntimePlatform.Type.Linux
+				&& RuntimeInformation.ProcessArchitecture == Architecture.Arm64)
+			{
+				string? ProcPath = Environment.ProcessPath;
+				if (!string.IsNullOrEmpty(ProcPath) && Path.GetFileNameWithoutExtension(ProcPath) == "dotnet")
+				{
+					return new FileReference(ProcPath);
+				}
