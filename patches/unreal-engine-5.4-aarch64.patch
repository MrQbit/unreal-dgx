diff --git a/Engine/Build/BatchFiles/Linux/GitDependencies.sh b/Engine/Build/BatchFiles/Linux/GitDependencies.sh
index 8f4617295..57ada39ad 100755
--- a/Engine/Build/BatchFiles/Linux/GitDependencies.sh
+++ b/Engine/Build/BatchFiles/Linux/GitDependencies.sh
@@ -16,14 +16,18 @@ BASE_PATH="`dirname "$SCRIPT_PATH"`"
 cd ../../../..
 RESULT=0
 
+# aarch64 hosts: use the natively-built arm64 GitDependencies (Epic ships linux-x64 only)
+ARCH_DIR=linux-x64
+[ "$(uname -m)" = "aarch64" ] && ARCH_DIR=linux-arm64
+
 while : ; do
-        ./Engine/Binaries/DotNET/GitDependencies/linux-x64/GitDependencies $ARGS
+        ./Engine/Binaries/DotNET/GitDependencies/$ARCH_DIR/GitDependencies $ARGS
         RESULT=$?
 
         echo "Result: $RESULT"
         # quit if not crashed
         [[ $RESULT -lt 129 ]] && break
-        echo "./Engine/Binaries/DotNET/GitDependencies/linux-x64/GitDependencies $ARGS crashed with return code $RESULT" >> GitDependencies.crash.log
+        echo "./Engine/Binaries/DotNET/GitDependencies/$ARCH_DIR/GitDependencies $ARGS crashed with return code $RESULT" >> GitDependencies.crash.log
 done
 
 exit $RESULT
diff --git a/Engine/Build/BatchFiles/Linux/SetupDotnet.sh b/Engine/Build/BatchFiles/Linux/SetupDotnet.sh
index 813626fa6..ab6e91c22 100755
--- a/Engine/Build/BatchFiles/Linux/SetupDotnet.sh
+++ b/Engine/Build/BatchFiles/Linux/SetupDotnet.sh
@@ -5,9 +5,34 @@ START_DIR=`pwd`
 cd "$1"
 
 IS_DOTNET_INSTALLED=0
+
+# aarch64 hosts: Epic bundles only a linux-x64 dotnet, which cannot run natively here.
+# Force use of a system-installed arm64 .NET SDK and bypass the (x64-only) bundled one.
+# This block is authoritative on aarch64: it locates a system dotnet, marks it installed,
+# and skips the version-parsing block below (whose parser mishandles SDK strings like 8.0.422).
+if [ "$(uname -m)" = "aarch64" ]; then
+	export UE_USE_SYSTEM_DOTNET=1
+	if ! command -v dotnet >/dev/null 2>&1; then
+		for CANDIDATE in "$HOME/.dotnet" /usr/lib/dotnet /usr/share/dotnet; do
+			if [ -x "$CANDIDATE/dotnet" ]; then
+				export DOTNET_ROOT="$CANDIDATE"
+				export PATH="$CANDIDATE:$PATH"
+				break
+			fi
+		done
+	fi
+	if command -v dotnet >/dev/null 2>&1; then
+		[ -z "$DOTNET_ROOT" ] && export DOTNET_ROOT="$(dirname "$(command -v dotnet)")"
+		IS_DOTNET_INSTALLED=1
+		echo "Using system arm64 .NET SDK: $(command -v dotnet) ($(dotnet --version 2>/dev/null))"
+	else
+		echo "ERROR: aarch64 host but no system dotnet found (install an arm64 .NET SDK to ~/.dotnet)"
+	fi
+fi
+
 DOTNET_VERSION_PATH=$(command -v dotnet) || true
 
-if [ "$UE_USE_SYSTEM_DOTNET" == "1" ] && [ ! $DOTNET_VERSION_PATH == "" ] && [ -f $DOTNET_VERSION_PATH ]; then
+if [ $IS_DOTNET_INSTALLED -eq 0 ] && [ "$UE_USE_SYSTEM_DOTNET" == "1" ] && [ ! $DOTNET_VERSION_PATH == "" ] && [ -f $DOTNET_VERSION_PATH ]; then
 	# If dotnet is installed, check that it has a new enough version of the SDK
 	DOTNET_SDKS=(`dotnet --list-sdks | grep -P "(\d*)\.(\d*)\..* \[(.*)\]"`)
 	for DOTNET_SDK in $DOTNET_SDKS
