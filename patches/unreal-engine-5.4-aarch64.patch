diff --git a/Engine/Source/UnrealEditor.Target.cs b/Engine/Source/UnrealEditor.Target.cs
index 5f7cb7bc4..917a22bfc 100644
--- a/Engine/Source/UnrealEditor.Target.cs
+++ b/Engine/Source/UnrealEditor.Target.cs
@@ -12,5 +12,46 @@ public class UnrealEditorTarget : TargetRules
 		BuildEnvironment = TargetBuildEnvironment.Shared;
 		bBuildAllModules = true;
 		ExtraModuleNames.Add("UnrealGame");
+
+		// On aarch64 hosts, "build all modules" pulls in many optional plugins whose third-party
+		// dependencies are x86-only or proprietary (USD, various importers) and not yet ported.
+		// Build only what the editor actually needs so it can boot; individual plugins can be
+		// re-enabled once their deps are ported. Gated by env var (target rules cannot reference
+		// RuntimeInformation to detect the host arch directly).
+		if (System.Environment.GetEnvironmentVariable("UE_ARM64_MINIMAL_EDITOR") == "1")
+		{
+			// Full build so ALL target-platform modules are registered (fixes the RunningPlatform assert
+			// that a minimal build hits). This pulls in optional plugins with x86-only third-party libs
+			// (OpenCV, EOS, Steam, OpenXR, WebRTC, libvpx, Bink, ONNX/IREE, msquic, protobuf). Since
+			// DisablePlugins is soft (loses to hard deps), those libs are instead replaced in-place with
+			// aarch64 no-op STUB libraries (scripts/stub_x86_lib.sh) so everything links. USD is disabled
+			// on arm64 (UnrealUSDWrapper.Build.cs EnableUsdSdk) and compiles without the SDK.
+			bBuildAllModules = true;
+
+			// CEF3 (Chromium Embedded Framework) ships x86_64-only prebuilt binaries and cannot be
+			// rebuilt for arm64 here; disabling it compiles the WebBrowser modules' non-CEF path.
+			bCompileCEF3 = false;
+			// (ISPC is disabled for aarch64 in UEBuildLinux.SetUpPlatformEnvironment — bCompileISPC has
+			// RequiresUniqueBuildEnvironment so it can't be overridden here in a Shared-environment target.)
+
+			DisablePlugins.Add("PerforceSourceControl");    // x86 P4 API
+			DisablePlugins.Add("ChangelistReview");         // x86 P4 API
+			DisablePlugins.Add("KDevelopSourceCodeAccess"); // x86 P4 API
+
+			// Optional plugins that can't build on arm64: their SOURCE needs x86-only headers/intrinsics
+			// (WebRTC/msquic/SSE2), or their x86 libs can't be cleanly stubbed (C++ std:: API →
+			// libstdc++-vs-libc++ mangling mismatch, or stacked stubs collide). Because DisablePlugins is
+			// soft (loses to hard deps), this is the FULL module-level dependent closure of the roots
+			// {NNERuntimeORT/IREE, PixelStreaming, MovieRenderPipeline, nDisplay, BlackmagicMedia,
+			// QuicMessaging} — computed so nothing hard-references a disabled plugin. All are optional
+			// (media codecs, virtual production, NN runtimes, movie render pipeline).
+			foreach (string P in new string[] {
+				"AppleProResMedia", "Avalanche", "AvidDNxMedia", "BinkMedia", "BlackmagicMedia",
+				"CinematicPrestreaming", "DMXDisplayCluster", "LiveLinkOverNDisplay", "MoviePipelineMaskRenderPass",
+				"MovieRenderPipeline", "NNERuntimeIREE", "NNERuntimeORT", "NNERuntimeRDG", "NiagaraMRQ",
+				"PixelStreaming", "PixelStreamingPlayer", "PixelCapture", "QuicMessaging", "RenderGrid",
+				"RivermaxSync", "TextureShare", "VertexDeltaModel", "VirtualCameraCore", "nDisplay",
+			}) { DisablePlugins.Add(P); }
+		}
 	}
